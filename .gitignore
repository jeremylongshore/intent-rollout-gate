# ============================================================================
# intent-rollout-gate — .gitignore
# Runtime language locked to TypeScript / Node by DR-002
# (000-docs/004-AT-DECR-runtime-language-typescript-2026-06-10.md).
# NOTE: dist/ is COMMITTED on purpose — GitHub Actions convention; the
# dist-sync CI job verifies it matches src/ on every PR.
# ============================================================================

# --- OS / editor ------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# --- Secrets / local env ---------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
!cosign.pub
secrets/
.secrets/

# --- Node / TypeScript -----------------------------------------------------
node_modules/
build/
out/
*.tsbuildinfo
.npm/
.pnpm-store/
.yarn/
yarn-error.log
npm-debug.log*
pnpm-debug.log*
.eslintcache
coverage/
.nyc_output/

# --- Beads -----------------------------------------------------------------
# Beads sqlite is local; the .beads/ dir is shared via bd sync, not git.
.beads/*.db
.beads/*.db-journal
.beads/*.db-shm
.beads/*.db-wal

# --- Evidence Bundles (test fixtures) -------------------------------------
# Real bundles produced during integration tests don't belong in git;
# fixture bundles under tests/fixtures/ are the exception.
evidence/
!tests/fixtures/evidence/

# --- Cosign / signing artifacts -------------------------------------------
*.sig
*.crt
*.pub.bak

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
