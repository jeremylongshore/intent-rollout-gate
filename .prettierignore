# Prettier ignore — intent-rollout-gate
#
# dist/index.js is the COMMITTED Action artifact, generated by esbuild from
# src/ and verified by the CI dist-sync gate. Prettier must never touch it.
dist/
node_modules/
coverage/
pnpm-lock.yaml

# Vendored audit-harness — owned upstream, hash-pinned.
.audit-harness/

# action.yml is the gate's I/O contract — hash-pinned in .harness-hash and
# validated by the structural check in ci.yml. Not prettier's surface.
action.yml

# Markdown is owned by markdownlint-cli2 (see .markdownlint-cli2.jsonc),
# not prettier, to avoid two formatters fighting over the same files.
*.md

# Test fixtures are byte-exact evidence/policy inputs — reformatting them
# would change the bytes the gate reads.
tests/fixtures/

# Tool-managed state — not source we format.
.beads/
.claude/
